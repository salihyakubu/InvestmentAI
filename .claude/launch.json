{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["api.main:app", "--reload", "--host", "0.0.0.0", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "worker",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "services.worker"],
      "port": 9100
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    }
  ]
}
