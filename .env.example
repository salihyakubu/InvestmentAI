# Database
DATABASE_URL=postgresql+asyncpg://investai:investai@localhost:5432/investai
REDIS_URL=redis://localhost:6379/0

# Alpaca (stocks) - Get keys at https://app.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Binance (crypto) - Get keys at https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# Trading
TRADING_MODE=paper
INITIAL_CAPITAL=100.00

# Auth
JWT_SECRET=change-this-to-a-random-secret-key

# Monitoring
PROMETHEUS_ENABLED=true
